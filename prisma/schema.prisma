generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int                       @id @default(autoincrement())
  username                 String                    @unique
  email                    String?                   @unique
  passwordHash             String
  role                     Role                      @default(USER)
  status                   UserStatus                @default(ACTIVE)
  lastLoginAt              DateTime?
  aiUsageLogs              AiUsageLog[]
  ragQueryLogs             RagQueryLog[]
  articleChatConversations ArticleChatConversation[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model Post {
  id                       Int                       @id @default(autoincrement())
  title                    String
  slug                     String                    @unique
  summary                  String?
  content                  String
  cover                    String?
  status                   PostStatus                @default(DRAFT)
  viewCount                Int                       @default(0)
  categoryId               Int?
  category                 Category?                 @relation(fields: [categoryId], references: [id])
  tags                     PostTag[]
  seoTitle                 String?
  seoDescription           String?
  isPinned                 Boolean                   @default(false)
  pinnedAt                 DateTime?
  relations                PostRelation[]            @relation("PostRelations")
  relatedBy                PostRelation[]            @relation("RelatedPostRelations")
  chunks                   PostChunk[]
  knowledgeDocument        KnowledgeDocument?
  knowledgeSyncJobs        KnowledgeSyncJob[]
  articleChatConversations ArticleChatConversation[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  publishedAt              DateTime?

  @@index([slug])
  @@index([status])
  @@index([isPinned, pinnedAt])
  @@index([publishedAt])
  @@index([categoryId])
}

model ArticleChatConversation {
  id               Int                  @id @default(autoincrement())
  postId           Int
  userId           Int?
  anonymousKeyHash String?
  status           ArticleChatStatus    @default(ACTIVE)
  lastMessageAt    DateTime             @default(now())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  post             Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  user             User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         ArticleChatMessage[]

  @@index([postId, userId, lastMessageAt])
  @@index([postId, anonymousKeyHash, lastMessageAt])
}

model ArticleChatMessage {
  id             Int                      @id @default(autoincrement())
  conversationId Int
  role           ArticleChatRole
  content        String
  status         ArticleChatMessageStatus @default(COMPLETED)
  citations      Json?
  durationMs     Int?
  error          String?
  createdAt      DateTime                 @default(now())
  conversation   ArticleChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  icon      String?
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  posts     PostTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model PostRelation {
  id            Int                @id @default(autoincrement())
  postId        Int
  relatedPostId Int
  reason        String?
  type          PostRelationType
  source        PostRelationSource @default(AI)
  sort          Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  post          Post               @relation("PostRelations", fields: [postId], references: [id], onDelete: Cascade)
  relatedPost   Post               @relation("RelatedPostRelations", fields: [relatedPostId], references: [id], onDelete: Cascade)

  @@unique([postId, relatedPostId])
  @@index([postId, sort])
  @@index([relatedPostId])
}

model PostChunk {
  id             Int                          @id @default(autoincrement())
  postId         Int
  chunkIndex     Int
  title          String
  slug           String
  summary        String?
  content        String
  headingPath    String?
  contentHash    String
  tokenCount     Int                          @default(0)
  categoryId     Int?
  tagIds         String                       @default("[]")
  embeddingModel String
  embeddingDim   Int
  embedding      Unsupported("vector(1536)")?
  status         PostChunkStatus              @default(ACTIVE)
  indexedAt      DateTime                     @default(now())
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  post           Post                         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, chunkIndex])
  @@index([postId])
  @@index([categoryId])
  @@index([contentHash])
  @@index([embeddingModel])
  @@index([status])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Menu {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  description String?
  location    MenuLocation @default(CUSTOM)
  isActive    Boolean      @default(true)
  items       MenuItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([location])
  @@index([isActive])
}

model MenuItem {
  id          Int          @id @default(autoincrement())
  menuId      Int
  parentId    Int?
  title       String
  url         String?
  type        MenuItemType @default(CUSTOM)
  targetId    Int?
  targetSlug  String?
  targetBlank Boolean      @default(false)
  badge       String?
  icon        String?
  sort        Int          @default(0)
  isVisible   Boolean      @default(true)
  menu        Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent      MenuItem?    @relation("MenuItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    MenuItem[]   @relation("MenuItemTree")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([menuId, sort])
  @@index([parentId])
  @@index([type, targetId])
}

model AiUsageLog {
  id        Int           @id @default(autoincrement())
  userId    Int
  feature   String
  status    AiUsageStatus
  ip        String?
  userAgent String?
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([ip, createdAt])
}

model KnowledgeDocument {
  id             Int                     @id @default(autoincrement())
  postId         Int                     @unique
  enabled        Boolean                 @default(true)
  status         KnowledgeDocumentStatus @default(PENDING)
  sourceHash     String
  indexedHash    String?
  chunkCount     Int                     @default(0)
  tokenCount     Int                     @default(0)
  embeddingModel String?
  embeddingDim   Int?
  lastIndexedAt  DateTime?
  lastError      String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  post           Post                    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([enabled, status])
  @@index([lastIndexedAt])
}

model KnowledgeSyncJob {
  id              Int                    @id @default(autoincrement())
  type            KnowledgeSyncJobType
  status          KnowledgeSyncJobStatus @default(PENDING)
  postId          Int?
  knowledgeFileId Int?
  totalItems      Int                    @default(0)
  completedItems  Int                    @default(0)
  successItems    Int                    @default(0)
  failedItems     Int                    @default(0)
  error           String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  post            Post?                  @relation(fields: [postId], references: [id], onDelete: SetNull)
  knowledgeFile   KnowledgeFile?         @relation(fields: [knowledgeFileId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([postId, createdAt])
  @@index([knowledgeFileId, createdAt])
}

model KnowledgeFile {
  id             Int                     @id @default(autoincrement())
  name           String
  originalName   String
  storedName     String                  @unique
  mimeType       String
  extension      String
  size           Int
  fileHash       String
  enabled        Boolean                 @default(true)
  status         KnowledgeDocumentStatus @default(PENDING)
  chunkCount     Int                     @default(0)
  tokenCount     Int                     @default(0)
  embeddingModel String?
  embeddingDim   Int?
  lastIndexedAt  DateTime?
  lastError      String?
  chunks         KnowledgeFileChunk[]
  syncJobs       KnowledgeSyncJob[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([enabled, status])
  @@index([fileHash])
  @@index([createdAt])
}

model KnowledgeFileChunk {
  id              Int                          @id @default(autoincrement())
  knowledgeFileId Int
  chunkIndex      Int
  title           String
  content         String
  headingPath     String?
  pageNumber      Int?
  contentHash     String
  tokenCount      Int                          @default(0)
  embeddingModel  String
  embeddingDim    Int
  embedding       Unsupported("vector(1536)")?
  status          PostChunkStatus              @default(ACTIVE)
  indexedAt       DateTime                     @default(now())
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  knowledgeFile   KnowledgeFile                @relation(fields: [knowledgeFileId], references: [id], onDelete: Cascade)

  @@unique([knowledgeFileId, chunkIndex])
  @@index([knowledgeFileId])
  @@index([contentHash])
  @@index([embeddingModel])
  @@index([status])
}

model RagQueryLog {
  id                Int            @id @default(autoincrement())
  userId            Int?
  question          String
  rewrittenQuestion String?
  answer            String?
  status            RagQueryStatus
  retrievedChunks   Json?
  citations         Json?
  retrievalMs       Int?
  modelMs           Int?
  durationMs        Int?
  inputTokens       Int?
  outputTokens      Int?
  feedback          Int?
  error             String?
  createdAt         DateTime       @default(now())
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PostChunkStatus {
  ACTIVE
  STALE
}

enum PostRelationType {
  PREREQUISITE
  EXTENSION
  SAME_TOPIC
  PRACTICE
  BACKGROUND
}

enum PostRelationSource {
  AI
  MANUAL
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AiUsageStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum KnowledgeDocumentStatus {
  PENDING
  SYNCING
  SYNCED
  STALE
  FAILED
  DISABLED
}

enum KnowledgeSyncJobType {
  SINGLE_POST
  BATCH_SYNC
  FULL_REBUILD
  REMOVE_STALE
  FILE_SYNC
}

enum KnowledgeSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL_FAILED
  FAILED
}

enum RagQueryStatus {
  SUCCESS
  NO_KNOWLEDGE
  FAILED
}

enum ArticleChatStatus {
  ACTIVE
  ARCHIVED
}

enum ArticleChatRole {
  USER
  ASSISTANT
}

enum ArticleChatMessageStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MenuLocation {
  PRIMARY
  FOOTER
  MOBILE
  CUSTOM
}

enum MenuItemType {
  CUSTOM
  POST
  CATEGORY
  TAG
  PAGE
  ARCHIVE
  HOME
}
