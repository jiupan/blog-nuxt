generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  role         Role     @default(USER)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  aiUsageLogs  AiUsageLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id             Int        @id @default(autoincrement())
  title          String
  slug           String     @unique
  summary        String?
  content        String
  cover          String?
  status         PostStatus @default(DRAFT)
  viewCount      Int        @default(0)
  categoryId     Int?
  category       Category?  @relation(fields: [categoryId], references: [id])
  tags           PostTag[]
  seoTitle       String?
  seoDescription String?
  isPinned       Boolean    @default(false)
  pinnedAt       DateTime?
  relations      PostRelation[] @relation("PostRelations")
  relatedBy      PostRelation[] @relation("RelatedPostRelations")
  chunks         PostChunk[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  publishedAt    DateTime?

  @@index([slug])
  @@index([status])
  @@index([isPinned, pinnedAt])
  @@index([publishedAt])
  @@index([categoryId])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  icon      String?
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  posts     PostTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model PostRelation {
  id            Int                @id @default(autoincrement())
  postId        Int
  relatedPostId Int
  reason        String?
  type          PostRelationType
  source        PostRelationSource @default(AI)
  sort          Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  post          Post               @relation("PostRelations", fields: [postId], references: [id], onDelete: Cascade)
  relatedPost   Post               @relation("RelatedPostRelations", fields: [relatedPostId], references: [id], onDelete: Cascade)

  @@unique([postId, relatedPostId])
  @@index([postId, sort])
  @@index([relatedPostId])
}

model PostChunk {
  id             Int             @id @default(autoincrement())
  postId         Int
  chunkIndex     Int
  title          String
  slug           String
  summary        String?
  content        String
  headingPath    String?
  contentHash    String
  tokenCount     Int             @default(0)
  categoryId     Int?
  tagIds         String          @default("[]")
  embeddingModel String
  embeddingDim   Int
  embedding      Unsupported("vector")?
  status         PostChunkStatus @default(ACTIVE)
  indexedAt      DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  post           Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, chunkIndex])
  @@index([postId])
  @@index([categoryId])
  @@index([contentHash])
  @@index([embeddingModel])
  @@index([status])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Menu {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  description String?
  location    MenuLocation @default(CUSTOM)
  isActive    Boolean      @default(true)
  items       MenuItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([location])
  @@index([isActive])
}

model MenuItem {
  id          Int          @id @default(autoincrement())
  menuId      Int
  parentId    Int?
  title       String
  url         String?
  type        MenuItemType @default(CUSTOM)
  targetId    Int?
  targetSlug  String?
  targetBlank Boolean      @default(false)
  badge       String?
  icon        String?
  sort        Int          @default(0)
  isVisible   Boolean      @default(true)
  menu        Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent      MenuItem?    @relation("MenuItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    MenuItem[]   @relation("MenuItemTree")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([menuId, sort])
  @@index([parentId])
  @@index([type, targetId])
}

model AiUsageLog {
  id         Int           @id @default(autoincrement())
  userId     Int
  feature    String
  status     AiUsageStatus
  ip         String?
  userAgent  String?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([ip, createdAt])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PostChunkStatus {
  ACTIVE
  STALE
}

enum PostRelationType {
  PREREQUISITE
  EXTENSION
  SAME_TOPIC
  PRACTICE
  BACKGROUND
}

enum PostRelationSource {
  AI
  MANUAL
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AiUsageStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum MenuLocation {
  PRIMARY
  FOOTER
  MOBILE
  CUSTOM
}

enum MenuItemType {
  CUSTOM
  POST
  CATEGORY
  TAG
  PAGE
  ARCHIVE
  HOME
}
